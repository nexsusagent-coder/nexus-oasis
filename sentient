#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
#  SENTIENT NEXUS OS - Global Launcher v1.0.0
#  Usage: sentient [command]
# ═══════════════════════════════════════════════════════════════════════════════

set -e

# Installation directory
SENTIENT_DIR="${SENTIENT_HOME:-$HOME/.sentient}"
SENTIENT_BIN="$SENTIENT_DIR/target/release"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Check if installed
check_installation() {
    if [ ! -d "$SENTIENT_DIR" ]; then
        echo -e "${RED}SENTIENT not installed.${NC}"
        echo ""
        echo "Install with:"
        echo -e "  ${CYAN}curl -sSL https://get.sentient.ai | bash${NC}"
        echo ""
        exit 1
    fi
}

# Show help
show_help() {
    echo -e "${CYAN}SENTIENT NEXUS OS - Professional AI Agent Framework${NC}"
    echo ""
    echo "Usage: sentient [command]"
    echo ""
    echo "Commands:"
    echo "  dashboard, ui    Launch the interactive dashboard (default)"
    echo "  shell, cli       Launch the CLI interface"
    echo "  setup            Run the setup wizard"
    echo "  config           Edit configuration"
    echo "  status           Show system status"
    echo "  update           Update to latest version"
    echo "  logs             View logs"
    echo "  help             Show this help"
    echo ""
    echo "Examples:"
    echo "  sentient              # Launch dashboard"
    echo "  sentient setup        # Configure SENTIENT"
    echo "  sentient status       # Check status"
    echo ""
}

# Show status
show_status() {
    check_installation
    
    echo -e "${CYAN}SENTIENT System Status${NC}"
    echo ""
    echo -e "  ${BOLD}Installation:${NC} $SENTIENT_DIR"
    
    # Check binary
    if [ -f "$SENTIENT_BIN/sentient-shell" ]; then
        echo -e "  ${BOLD}Status:${NC}       ${GREEN}Installed${NC}"
    else
        echo -e "  ${BOLD}Status:${NC}       ${YELLOW}Not built (run: cd $SENTIENT_DIR && cargo build --release)${NC}"
    fi
    
    # Check config
    if [ -f "$SENTIENT_DIR/.env" ]; then
        echo -e "  ${BOLD}Config:${NC}       ${GREEN}Configured${NC}"
    else
        echo -e "  ${BOLD}Config:${NC}       ${YELLOW}Not configured (run: sentient setup)${NC}"
    fi
    
    # Check Ollama
    if command -v ollama &> /dev/null; then
        echo -e "  ${BOLD}Ollama:${NC}       ${GREEN}Installed${NC}"
    else
        echo -e "  ${BOLD}Ollama:${NC}       ${YELLOW}Not installed (for local models: https://ollama.com)${NC}"
    fi
    
    echo ""
}

# Update
do_update() {
    check_installation
    
    echo -e "${CYAN}Updating SENTIENT...${NC}"
    cd "$SENTIENT_DIR"
    
    git pull origin main 2>/dev/null || git pull origin master 2>/dev/null || {
        echo -e "${YELLOW}Git pull failed. Trying anyway...${NC}"
    }
    
    echo -e "${YELLOW}Building...${NC}"
    cargo build --release --bin sentient-setup --bin sentient-shell
    
    echo -e "${GREEN}Update complete!${NC}"
}

# Main
case "${1:-dashboard}" in
    dashboard|ui|"")
        check_installation
        
        if [ -f "$SENTIENT_BIN/sentient-shell" ]; then
            cd "$SENTIENT_DIR"
            exec "$SENTIENT_BIN/sentient-shell" "$@"
        else
            echo -e "${RED}sentient-shell not found. Building...${NC}"
            cd "$SENTIENT_DIR"
            cargo build --release --bin sentient-shell
            exec "$SENTIENT_BIN/sentient-shell" "$@"
        fi
        ;;
    
    shell|cli|repl)
        check_installation
        
        if [ -f "$SENTIENT_BIN/sentient-shell" ]; then
            cd "$SENTIENT_DIR"
            exec "$SENTIENT_BIN/sentient-shell" "$@"
        else
            echo -e "${RED}sentient-shell not found.${NC}"
            exit 1
        fi
        ;;
    
    setup|configure|init)
        check_installation
        
        if [ -f "$SENTIENT_BIN/sentient-setup" ]; then
            exec "$SENTIENT_BIN/sentient-setup"
        else
            echo -e "${YELLOW}Building sentient-setup...${NC}"
            cd "$SENTIENT_DIR"
            cargo build --release --bin sentient-setup
            exec "$SENTIENT_BIN/sentient-setup"
        fi
        ;;
    
    config)
        check_installation
        
        if [ -f "$SENTIENT_DIR/.env" ]; then
            ${EDITOR:-nano} "$SENTIENT_DIR/.env"
        else
            echo -e "${YELLOW}Config not found. Run: sentient setup${NC}"
        fi
        ;;
    
    status)
        show_status
        ;;
    
    update|upgrade)
        do_update
        ;;
    
    logs)
        check_installation
        
        LOG_DIR="$SENTIENT_DIR/logs"
        if [ -d "$LOG_DIR" ]; then
            tail -f "$LOG_DIR"/*.log 2>/dev/null || ls -la "$LOG_DIR"
        else
            echo -e "${YELLOW}No logs found.${NC}"
        fi
        ;;
    
    help|--help|-h)
        show_help
        ;;
    
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        show_help
        exit 1
        ;;
esac
