{
  "name": "git-workflow",
  "version": "1.0.0",
  "description": "Gelişmiş Git iş akışı yönetimi: branch, commit, PR, merge conflict çözümü",
  "author": "ASENA_CORE",
  "category": "development",
  "permissions": {
    "file_read": true,
    "file_write": true,
    "bash_execute": true,
    "network_access": false
  },
  "parameters": {
    "action": {
      "type": "string",
      "required": true,
      "description": "Git işlemi"
    },
    "message": {
      "type": "string",
      "required": false,
      "description": "Commit mesajı"
    },
    "branch_name": {
      "type": "string",
      "required": false,
      "description": "Branch adı"
    }
  },
  "tools": ["bash", "read_file", "edit_file"],
  "output_format": {
    "type": "structured"
  },
  "rate_limit": {
    "requests_per_minute": 30,
    "max_tokens": 4000
  },
  "metadata": {
    "tags": ["git", "version-control", "workflow", "automation"],
    "priority": "high",
    "hot_reload": true
  }
}
