#!/usr/bin/env python3
"""
{{name}} - ASENA Forge tarafindan uretilmistir
"""

import requests
import json
from typing import Dict, Any

BASE_URL = "{{base_url}}"

def main():
    """Ana fonksiyon"""
    print(f"[{{name}}] Baslatiliyor...")
    
    response = requests.get(BASE_URL)
    
    if response.ok:
        data = response.json()
        print(f"Veri alindi: {len(str(data))} karakter")
        return data
    else:
        print(f"Hata: {response.status_code}")
        return None

if __name__ == "__main__":
    main()
