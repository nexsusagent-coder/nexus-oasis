# SENTIENT AI OS - Minimal Dockerfile
# Smallest possible image for edge deployments

# ============================================
# Build stage
# ============================================
FROM rust:1.75-alpine AS builder

RUN apk add --no-cache musl-dev openssl-dev openssl-libs-static pkgconfig protobuf

WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates

RUN cargo build --release -p sentient_cli --no-default-features

# ============================================
# Runtime stage (minimal)
# ============================================
FROM alpine:3.19

RUN apk add --no-cache ca-certificates libgcc

# Create non-root user
RUN adduser -D -u 1000 sentient

WORKDIR /app

# Copy only the binary
COPY --from=builder /app/target/release/sentient /usr/local/bin/

# Set ownership
RUN chown -R sentient:sentient /app

USER sentient

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget -q --spider http://localhost:8080/health || exit 1

CMD ["sentient", "gateway"]

# ============================================
# Labels
# ============================================
LABEL org.opencontainers.image.title="SENTIENT AI OS (Minimal)"
LABEL org.opencontainers.image.description="Minimal image for edge deployments"
LABEL org.opencontainers.image.version="11.0.0-minimal"
