# SENTIENT AI OS - Development Dockerfile
# Hot-reload enabled development environment

FROM rust:1.75-bookworm

# Install development tools
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    protobuf-compiler \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install cargo-watch for hot reload
RUN cargo install cargo-watch

# Install other useful tools
RUN cargo install \
    cargo-edit \
    cargo-outdated \
    cargo-tree \
    cargo-audit

WORKDIR /app

# Copy manifests first for caching
COPY Cargo.toml Cargo.lock ./

# Create dummy main to cache dependencies
RUN mkdir -p crates/sentient_cli/src && \
    echo "fn main() {}" > crates/sentient_cli/src/main.rs

# Build dependencies
RUN cargo build

# Copy source code
COPY . .

# Expose ports
EXPOSE 8080 8443 9229

# Set environment
ENV RUST_LOG=debug
ENV RUST_BACKTRACE=1

# Run with hot reload
CMD ["cargo", "watch", "-x", "run -p sentient_gateway", "-w", "crates"]
